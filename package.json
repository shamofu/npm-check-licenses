{
  "name": "npm-check-licenses",
  "version": "2.0.0",
  "description": "Check what license you can apply.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "ncl": "bin/ncl.js",
    "npm-check-licenses": "bin/npm-check-licenses.js"
  },
  "scripts": {
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "author": "shamofu",
  "keywords": [
    "spdx",
    "npm",
    "check",
    "license",
    "package.json"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shamofu/npm-check-licenses.git"
  },
  "bugs": {
    "url": "https://github.com/shamofu/npm-check-licenses/issues"
  },
  "homepage": "https://github.com/shamofu/npm-check-licenses#readme",
  "dependencies": {
    "commander": "^14.0.3",
    "ink": "^5.2.0",
    "ink-spinner": "^5.0.0",
    "is-online": "^12.0.2",
    "react": "^18.3.1",
    "spdx-correct": "^3.2.0",
    "spdx-expression-parse": "^4.0.0",
    "spdx-expression-validate": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/spdx-correct": "^3.1.3",
    "@types/spdx-expression-parse": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
